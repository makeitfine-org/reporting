# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Admin DB — used to initialize the postgres container (POSTGRES_DB env var creates this DB)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_LOCALHOST_REDIRECT_PORT=5432
POSTGRES_DB=reporting
POSTGRES_USER=reporting
POSTGRES_PASSWORD=reporting

# Per-service credentials — must stay in sync with infra/postgres/init-databases.sql
CUSTOMER_POSTGRES_URL=jdbc:postgresql://postgres:5432/customers
CUSTOMER_POSTGRES_USER=customers
CUSTOMER_POSTGRES_PASSWORD=customers

PRODUCT_POSTGRES_URL=jdbc:postgresql://postgres:5432/products
PRODUCT_POSTGRES_USER=products
PRODUCT_POSTGRES_PASSWORD=products

TRANSACTION_POSTGRES_URL=jdbc:postgresql://postgres:5432/transactions
TRANSACTION_POSTGRES_USER=transactions
TRANSACTION_POSTGRES_PASSWORD=transactions

NOTIFICATION_POSTGRES_URL=jdbc:postgresql://postgres:5432/notifications
NOTIFICATION_POSTGRES_USER=notifications
NOTIFICATION_POSTGRES_PASSWORD=notifications

# reporting-service reuses the admin POSTGRES_USER / POSTGRES_PASSWORD above
REPORTING_POSTGRES_URL=jdbc:postgresql://postgres:5432/reporting

# ─── Kafka / Zookeeper ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_LOCALHOST_REDIRECT_PORT=29092

# ─── Elasticsearch ─────────────────────────────────────────────────────────────
ES_URIS=http://elasticsearch:9200
ES_LOCALHOST_REDIRECT_PORT=9200

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_LOCALHOST_REDIRECT_PORT=6379

# ─── MailHog (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
MAILHOG_SMTP_LOCALHOST_REDIRECT_PORT=1025
MAILHOG_UI_LOCALHOST_REDIRECT_PORT=8025

# ─── Observability ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ─── Services ──────────────────────────────────────────────────────────────────
CUSTOMER_SERVICE_URL=http://customer-service:8081
CUSTOMER_SERVICE_PORT=8081
CUSTOMER_SERVICE_LOCALHOST_REDIRECT_PORT=8081

PRODUCT_SERVICE_URL=http://product-service:8083
PRODUCT_SERVICE_PORT=8083
PRODUCT_SERVICE_LOCALHOST_REDIRECT_PORT=8083

TRANSACTION_SERVICE_PORT=8082
TRANSACTION_SERVICE_LOCALHOST_REDIRECT_PORT=8082

NOTIFICATION_SERVICE_PORT=8084
NOTIFICATION_SERVICE_LOCALHOST_REDIRECT_PORT=8084

REPORTING_SERVICE_PORT=8080
REPORTING_SERVICE_LOCALHOST_REDIRECT_PORT=8080

# ─── Debug Ports ───────────────────────────────────────────────────────────────
REPORTING_SERVICE_DEBUG_PORT=5005
CUSTOMER_SERVICE_DEBUG_PORT=5006
PRODUCT_SERVICE_DEBUG_PORT=5007
TRANSACTION_SERVICE_DEBUG_PORT=5008
NOTIFICATION_SERVICE_DEBUG_PORT=5009
